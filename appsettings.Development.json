{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=habitdb.sqlite"
  },
  "JwtSettings": {
    "Secret": "your-super-secret-key-change-this-in-production-minimum-32-characters",
    "Issuer": "HabitSystem",
